    "qualifying_row_translation": "keep approved upstream std_icu_urine_output_event rows where charttime >= intime and charttime <= intime + 24 hours",
    "selection_translation": "include all qualifying first-day urine-output rows for each stay_id",
    "aggregation_translation": "sum urine_output_ml per stay_id as first_day_urine_output_ml",
    "tie_break_translation": "not applicable because all qualifying rows are summed",
    "no_source_row_translation": "retain every ICU stay row and set first_day_urine_output_ml to NULL when no qualifying first-day urine row exists",
    "partial_window_translation": "retain first_day_complete_24h_observed_flag and first_day_partial_window_caution_flag, but do not clip the official aggregation numerator by outtime"
  },
